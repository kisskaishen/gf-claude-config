{
  "name": "csd-gfuc-web",
  "private": true,
  "version": "1.26.03-12",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "eslint --ext .js,.ts,.vue src",
    "lint:fix": "eslint --ext .js,.ts,.vue src --fix",
    "stylelint": "stylelint \"src/**/*.{vue,scss,css}\"",
    "stylelint:fix": "stylelint \"src/**/*.{vue,scss,css}\" --fix",
    "type-check": "vue-tsc --noEmit -p tsconfig --skipLibCheck",
    "verify:fidelity": "tsx scripts/verify-fidelity.ts",
    "verify:fidelity:capture": "tsx scripts/verify-fidelity.ts --capture-only",
    "verify:fidelity:diff": "tsx scripts/verify-fidelity.ts --diff-only",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@datarangers/sdk-javascript": "^0.1.4",
    "@element-plus/icons-vue": "^2.3.2",
    "@zip.js/zip.js": "^2.8.26",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "element-plus": "^2.13.0",
    "file-saver": "^2.0.5",
    "jsencrypt": "^3.5.4",
    "jszip": "^3.10.1",
    "lodash-es": "^4.17.22",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.24",
    "vue-i18n": "11",
    "vue-router": "4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@pinia/testing": "^1.0.3",
    "@types/file-saver": "^2.0.7",
    "@types/jszip": "^3.4.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.1",
    "@types/pngjs": "^6.0.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.6.2",
    "fast-glob": "^3.3.3",
    "globals": "^17.0.0",
    "happy-dom": "^20.10.4",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.9",
    "postcss-html": "^1.8.1",
    "prettier": "3.8.0",
    "sass-embedded": "^1.97.1",
    "stylelint": "^17.0.0",
    "stylelint-config-recess-order": "^7.4.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.0",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.2.4",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.1.4"
  },
  "packageManager": "pnpm@9.5.0",
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{vue,scss,css}": [
      "stylelint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
